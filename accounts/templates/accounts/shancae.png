<!DOCTYPE html>
{% load static %}
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portal - Theta Tutorial Center</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --secondary: #764ba2;
            --success: #48bb78;
            --warning: #ed8936;
            --danger: #fc8181;
            --dark: #1a202c;
            --gray: #718096;
            --light-gray: #f7fafc;
            --white: #ffffff;
            --shadow: 0 10px 40px rgba(0,0,0,0.08);
            --shadow-hover: 0 20px 60px rgba(0,0,0,0.12);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #f0f4f8;
            color: var(--dark);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* ========== SHANCAE BACKGROUND WATERMARK ========== */
        .shancae-watermark {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-25deg);
            z-index: -1;
            pointer-events: none;
            opacity: 0.04;
            text-align: center;
            user-select: none;
        }

        .shancae-watermark .main-text {
            font-size: 130px;
            font-weight: 900;
            color: #1a202c;
            letter-spacing: 30px;
            text-transform: uppercase;
            font-family: 'Arial Black', 'Inter', sans-serif;
            text-shadow: 4px 4px 30px rgba(0,0,0,0.08);
            animation: shimmer 8s ease-in-out infinite;
        }

        .shancae-watermark .sub-text {
            font-size: 30px;
            font-weight: 300;
            color: #4a5568;
            letter-spacing: 15px;
            margin-top: 15px;
            font-family: 'Georgia', serif;
        }

        @keyframes shimmer {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        /* ========== ANIMATED BACKGROUND ========== */
        .animated-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            pointer-events: none;
        }

        .floating-shapes {
            position: absolute;
            border-radius: 50%;
            opacity: 0.08;
            animation: floatShape 20s ease-in-out infinite;
        }

        .floating-shapes:nth-child(1) {
            width: 300px;
            height: 300px;
            background: var(--primary);
            top: -5%;
            left: -5%;
            animation-delay: 0s;
        }

        .floating-shapes:nth-child(2) {
            width: 400px;
            height: 400px;
            background: var(--secondary);
            bottom: -10%;
            right: -5%;
            animation-delay: -5s;
        }

        .floating-shapes:nth-child(3) {
            width: 200px;
            height: 200px;
            background: var(--warning);
            top: 40%;
            right: 5%;
            animation-delay: -10s;
        }

        .floating-shapes:nth-child(4) {
            width: 150px;
            height: 150px;
            background: var(--success);
            bottom: 30%;
            left: 10%;
            animation-delay: -15s;
        }

        @keyframes floatShape {
            0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
            25% { transform: translate(50px, -40px) rotate(90deg) scale(1.1); }
            50% { transform: translate(-30px, 30px) rotate(180deg) scale(0.9); }
            75% { transform: translate(40px, 50px) rotate(270deg) scale(1.05); }
        }

        /* ========== FLOATING ICONS ========== */
        .floating-icons {
            position: fixed;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }

        .floating-icon {
            position: absolute;
            font-size: 30px;
            animation: floatIcon 15s ease-in-out infinite;
            opacity: 0.15;
        }

        .floating-icon:nth-child(1) { top: 10%; left: 5%; animation-delay: 0s; font-size: 40px; }
        .floating-icon:nth-child(2) { top: 20%; right: 8%; animation-delay: -3s; font-size: 35px; }
        .floating-icon:nth-child(3) { bottom: 30%; left: 3%; animation-delay: -6s; font-size: 45px; }
        .floating-icon:nth-child(4) { bottom: 20%; right: 5%; animation-delay: -9s; font-size: 38px; }
        .floating-icon:nth-child(5) { top: 50%; left: 50%; animation-delay: -12s; font-size: 50px; }

        @keyframes floatIcon {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            25% { transform: translateY(-20px) rotate(10deg); }
            50% { transform: translateY(10px) rotate(-5deg); }
            75% { transform: translateY(-15px) rotate(15deg); }
        }

        /* ========== HEADER WITH ETHIOPIAN FLAG ========== */
        .header {
            background: linear-gradient(135deg, #078930 0%, #FCDD09 50%, #EF1C24 100%);
            color: var(--white);
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            box-shadow: 0 4px 20px rgba(7, 137, 48, 0.3);
            position: sticky;
            top: 0;
            z-index: 100;
            position: relative;
            overflow: hidden;
        }

        .header::after {
            content: '🇪🇹';
            position: absolute;
            right: 30px;
            bottom: 10px;
            font-size: 70px;
            opacity: 0.12;
            pointer-events: none;
            animation: floatFlag 4s ease-in-out infinite;
        }

        @keyframes floatFlag {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-5px) rotate(2deg); }
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
            z-index: 1;
            position: relative;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            z-index: 1;
            position: relative;
        }

        .logo-container {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            flex-shrink: 0;
        }

        .logo-icon svg {
            width: 100%;
            height: 100%;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .logo-title {
            font-size: 24px;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -1px;
        }

        .logo-title span {
            font-weight: 300;
            opacity: 0.85;
        }

        .logo-subtitle {
            font-size: 11px;
            font-weight: 400;
            color: rgba(255,255,255,0.8);
            letter-spacing: 0.5px;
        }

        .logo-tagline {
            font-size: 9px;
            font-weight: 300;
            color: rgba(255,255,255,0.6);
            letter-spacing: 0.3px;
        }

        .nav-links a {
            color: var(--white);
            text-decoration: none;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 500;
            font-size: 14px;
            transition: var(--transition);
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links a:hover {
            background: rgba(255,255,255,0.3);
            transform: translateY(-2px);
        }

        .nav-links .logout-btn {
            background: rgba(255,255,255,0.2);
            border: 1px solid rgba(255,255,255,0.3);
        }

        .nav-links .logout-btn:hover {
            background: rgba(255,255,255,0.35);
        }

        /* ========== CONTAINER ========== */
        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
        }

        /* ========== PROFILE SECTION ========== */
        .profile-section {
            display: flex;
            align-items: center;
            gap: 24px;
            background: var(--white);
            padding: 24px 30px;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            margin-bottom: 30px;
            border: 1px solid rgba(102, 126, 234, 0.08);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .profile-section:hover {
            box-shadow: var(--shadow-hover);
        }

        .fasil-image {
            position: absolute;
            bottom: 10px;
            right: 15px;
            width: 120px;
            height: 80px;
            opacity: 0.1;
            pointer-events: none;
            z-index: 0;
            border-radius: 10px;
            object-fit: cover;
            animation: rotateImage 6s ease-in-out infinite;
        }

        @keyframes rotateImage {
            0%, 100% { transform: rotate(0deg) scale(1); }
            50% { transform: rotate(2deg) scale(1.03); }
        }

        .obelisk-image {
            position: absolute;
            bottom: 10px;
            left: 15px;
            width: 80px;
            height: 90px;
            opacity: 0.1;
            pointer-events: none;
            z-index: 0;
            border-radius: 10px;
            object-fit: cover;
            animation: pulseImage 4s ease-in-out infinite;
        }

        @keyframes pulseImage {
            0%, 100% { transform: scale(1) rotate(-2deg); }
            50% { transform: scale(1.06) rotate(2deg); }
        }

        .profile-picture {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid var(--primary);
            flex-shrink: 0;
            z-index: 1;
            position: relative;
            animation: pulseBorder 3s ease-in-out infinite;
        }

        @keyframes pulseBorder {
            0%, 100% { border-color: var(--primary); box-shadow: 0 0 0 0 rgba(102, 126, 234, 0.4); }
            50% { border-color: var(--secondary); box-shadow: 0 0 20px 5px rgba(118, 75, 162, 0.2); }
        }

        .profile-picture img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .profile-picture:hover img {
            transform: scale(1.1);
        }

        .profile-picture .initial {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            font-weight: 700;
            color: white;
        }

        .profile-info {
            z-index: 1;
            position: relative;
        }

        .profile-info h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 4px;
        }

        .profile-info h2 span {
            color: var(--primary);
        }

        .profile-info p {
            color: var(--gray);
            font-size: 14px;
        }

        .profile-info .badge {
            display: inline-block;
            background: var(--light-gray);
            padding: 4px 14px;
            border-radius: 50px;
            font-size: 13px;
            color: var(--gray);
            margin-top: 6px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 24px 20px;
            text-align: center;
            box-shadow: var(--shadow);
            border: 1px solid rgba(102, 126, 234, 0.06);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            animation: slideUp 0.8s ease-out forwards;
            opacity: 0;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            opacity: 0;
            transition: var(--transition);
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: var(--shadow-hover);
        }

        .stat-card .stat-icon {
            font-size: 28px;
            margin-bottom: 8px;
            display: block;
            animation: bounceIcon 2s ease-in-out infinite;
        }

        @keyframes bounceIcon {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }

        .stat-card .value {
            font-size: 32px;
            font-weight: 800;
            color: var(--dark);
            line-height: 1.2;
            animation: countUp 1s ease-out forwards;
        }

        @keyframes countUp {
            from { opacity: 0; transform: scale(0.5); }
            to { opacity: 1; transform: scale(1); }
        }

        .stat-card .value.primary { color: var(--primary); }
        .stat-card .value.success { color: var(--success); }
        .stat-card .value.warning { color: var(--warning); }
        .stat-card .value.danger { color: var(--danger); }

        .stat-card .label {
            color: var(--gray);
            font-size: 14px;
            font-weight: 500;
            margin-top: 4px;
        }

        .section {
            background: var(--white);
            border-radius: var(--radius);
            padding: 30px 35px;
            margin-bottom: 30px;
            box-shadow: var(--shadow);
            border: 1px solid rgba(102, 126, 234, 0.06);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .section-header h3 {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header .count {
            background: var(--light-gray);
            padding: 2px 12px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            color: var(--gray);
        }

        .lesson-item {
            padding: 18px 20px;
            border-bottom: 1px solid #eef2f6;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            transition: var(--transition);
            border-radius: 10px;
            animation: slideIn 0.6s ease-out forwards;
            opacity: 0;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .lesson-item:hover {
            background: var(--light-gray);
            transform: scale(1.01);
        }

        .lesson-item:last-child {
            border-bottom: none;
        }

        .lesson-info {
            flex: 2;
            min-width: 200px;
        }

        .lesson-title {
            font-weight: 600;
            font-size: 16px;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .lesson-title .lesson-type {
            font-size: 11px;
            font-weight: 600;
            padding: 2px 10px;
            border-radius: 50px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            animation: pulseType 2s ease-in-out infinite;
        }

        @keyframes pulseType {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .lesson-type.video { background: #fef3c7; color: #92400e; }
        .lesson-type.quiz { background: #dbeafe; color: #1e40af; }
        .lesson-type.article { background: #d1fae5; color: #065f46; }

        .lesson-topic {
            font-size: 14px;
            color: var(--gray);
            margin-top: 2px;
        }

        .watch-video-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 6px;
            padding: 5px 14px;
            background: #dc2626;
            color: var(--white);
            border: none;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            transition: var(--transition);
            cursor: pointer;
            animation: glowPulse 2s ease-in-out infinite;
        }

        @keyframes glowPulse {
            0%, 100% { box-shadow: 0 0 5px rgba(220, 38, 38, 0.3); }
            50% { box-shadow: 0 0 20px rgba(220, 38, 38, 0.6); }
        }

        .watch-video-btn:hover {
            background: #b91c1c;
            transform: scale(1.08);
        }

        .watch-video-btn i {
            animation: playPulse 1.5s ease-in-out infinite;
        }

        @keyframes playPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }

        .no-video {
            font-size: 12px;
            color: #a0aec0;
        }

        .lesson-progress {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            min-width: 180px;
            justify-content: flex-end;
        }

        .progress-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .progress-bar {
            width: 120px;
            height: 6px;
            background: #e2e8f0;
            border-radius: 50px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 50px;
            transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .progress-text {
            font-size: 14px;
            font-weight: 600;
            color: var(--gray);
            min-width: 40px;
            text-align: right;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 14px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-completed {
            background: #c6f6d5;
            color: #22543d;
        }

        .status-in_progress {
            background: #fefcbf;
            color: #744210;
        }

        .status-not_started {
            background: #e2e8f0;
            color: #4a5568;
        }

        .video-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .video-modal-content {
            background: #1a202c;
            border-radius: 16px;
            padding: 30px;
            max-width: 900px;
            width: 90%;
            max-height: 90vh;
            position: relative;
        }

        .video-modal-close {
            position: absolute;
            top: 15px;
            right: 20px;
            background: none;
            border: none;
            color: white;
            font-size: 28px;
            cursor: pointer;
            z-index: 10;
            transition: transform 0.3s;
        }

        .video-modal-close:hover {
            transform: rotate(90deg);
        }

        .video-modal-title {
            color: white;
            margin-bottom: 15px;
        }

        .video-container {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            overflow: hidden;
            border-radius: 10px;
            background: #000;
        }

        .video-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .video-actions {
            margin-top: 20px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .video-actions .btn-close {
            padding: 10px 24px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
        }

        .video-actions .btn-close:hover {
            background: #5a67d8;
        }

        .video-actions .btn-complete {
            padding: 10px 24px;
            background: #48bb78;
            color: white;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
        }

        .video-actions .btn-complete:hover {
            background: #38a169;
        }

        .confetti-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 9999;
            overflow: hidden;
        }

        .confetti {
            position: absolute;
            width: 10px;
            height: 10px;
            top: -10px;
            animation: confettiFall 3s ease-in forwards;
        }

        @keyframes confettiFall {
            0% { transform: translateY(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
        }

        .ethiopian-footer {
            background: #1a202c;
            color: white;
            padding: 40px 20px 30px;
            text-align: center;
            margin-top: 40px;
            position: relative;
            overflow: hidden;
        }

        .footer-fasil {
            position: absolute;
            bottom: 10px;
            left: 15px;
            width: 110px;
            height: 75px;
            opacity: 0.08;
            pointer-events: none;
            z-index: 0;
            border-radius: 10px;
            object-fit: cover;
            animation: floatCastle 7s ease-in-out infinite;
        }

        @keyframes floatCastle {
            0%, 100% { transform: translateY(0px) rotate(-2deg); }
            50% { transform: translateY(-10px) rotate(2deg); }
        }

        .footer-obelisk {
            position: absolute;
            top: 10px;
            right: 15px;
            width: 70px;
            height: 80px;
            opacity: 0.08;
            pointer-events: none;
            z-index: 0;
            border-radius: 10px;
            object-fit: cover;
            animation: swayImage 5s ease-in-out infinite;
        }

        @keyframes swayImage {
            0%, 100% { transform: rotate(-3deg) scale(1); }
            50% { transform: rotate(3deg) scale(1.05); }
        }

        .ethiopian-footer .flag-colors {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

        .ethiopian-footer .flag-colors .green { color: #078930; }
        .ethiopian-footer .flag-colors .yellow { color: #FCDD09; }
        .ethiopian-footer .flag-colors .red { color: #EF1C24; }

        .ethiopian-footer .footer-brand {
            font-size: 18px;
            font-weight: 700;
            color: #ffffff;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
        }

        .ethiopian-footer .footer-brand span {
            color: #667eea;
        }

        .ethiopian-footer .footer-contact {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            margin: 15px 0;
            color: #a0aec0;
            font-size: 14px;
            position: relative;
            z-index: 1;
        }

        .ethiopian-footer .footer-contact a {
            color: #a0aec0;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

        .ethiopian-footer .footer-contact a:hover {
            color: #667eea;
        }

        .ethiopian-footer .footer-contact i {
            color: #667eea;
        }

        .ethiopian-footer .footer-divider {
            border: none;
            border-top: 1px solid #2d3748;
            margin: 15px auto;
            max-width: 600px;
            position: relative;
            z-index: 1;
        }

        .ethiopian-footer .tagline {
            color: #718096;
            font-size: 12px;
            position: relative;
            z-index: 1;
        }

        @media (max-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .shancae-watermark .main-text {
                font-size: 80px;
                letter-spacing: 15px;
            }
            .shancae-watermark .sub-text {
                font-size: 20px;
                letter-spacing: 8px;
            }
        }

        @media (max-width: 768px) {
            .header {
                padding: 15px 20px;
                flex-direction: column;
                text-align: center;
            }
            .header-left { flex-direction: column; }
            .logo-container { flex-direction: column; text-align: center; }
            .logo-title { font-size: 20px; }
            .nav-links { justify-content: center; }
            .nav-links a { font-size: 13px; padding: 6px 14px; }
            .profile-section {
                flex-direction: column;
                text-align: center;
                padding: 20px;
            }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .stat-card { padding: 16px; }
            .stat-card .value { font-size: 24px; }
            .section { padding: 20px; }
            .lesson-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }
            .lesson-progress {
                width: 100%;
                justify-content: flex-start;
            }
            .ethiopian-footer .footer-contact {
                flex-direction: column;
                gap: 12px;
                align-items: center;
            }
            .header::after {
                font-size: 40px;
                right: 15px;
                bottom: 5px;
            }
            .video-modal-content {
                padding: 20px;
            }
            .shancae-watermark .main-text {
                font-size: 50px;
                letter-spacing: 10px;
            }
            .shancae-watermark .sub-text {
                font-size: 16px;
                letter-spacing: 5px;
            }
        }

        @media (max-width: 480px) {
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .stats-grid .stat-card:last-child { grid-column: span 2; }
            .header::after {
                font-size: 30px;
                right: 10px;
                bottom: 5px;
            }
            .shancae-watermark .main-text {
                font-size: 35px;
                letter-spacing: 5px;
            }
            .shancae-watermark .sub-text {
                font-size: 12px;
                letter-spacing: 3px;
            }
        }
    </style>
</head>
<body>
    <!-- SHANCAE BACKGROUND WATERMARK -->
    <div class="shancae-watermark">
        <div class="main-text">SHANCAE</div>
        <div class="sub-text">✦ ✧ ✦ ✧ ✦</div>
    </div>

    <!-- ANIMATED BACKGROUND -->
    <div class="animated-bg">
        <div class="floating-shapes"></div>
        <div class="floating-shapes"></div>
        <div class="floating-shapes"></div>
        <div class="floating-shapes"></div>
    </div>

    <!-- FLOATING ICONS -->
    <div class="floating-icons">
        <span class="floating-icon">📚</span>
        <span class="floating-icon">🎓</span>
        <span class="floating-icon">✏️</span>
        <span class="floating-icon">🌟</span>
        <span class="floating-icon">💡</span>
    </div>

    <!-- HEADER WITH ETHIOPIAN FLAG -->
    <div class="header">
        <div class="header-left">
            <div class="logo-container">
                <div class="logo-icon">
                    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="10,70 30,30 50,70" fill="#2d3748"/>
                        <polygon points="35,70 55,25 75,70" fill="#4a5568"/>
                        <polygon points="60,70 80,35 95,70" fill="#2d3748"/>
                        <polygon points="30,30 25,40 35,40" fill="white"/>
                        <polygon points="55,25 48,38 62,38" fill="white"/>
                        <polygon points="80,35 74,45 86,45" fill="white"/>
                        <circle cx="80" cy="20" r="12" fill="#f6ad55"/>
                        <circle cx="80" cy="20" r="10" fill="#ed8936"/>
                        <rect x="15" y="75" width="8" height="8" fill="#078930" rx="1"/>
                        <rect x="28" y="78" width="8" height="8" fill="#FCDD09" rx="1"/>
                        <rect x="41" y="75" width="8" height="8" fill="#EF1C24" rx="1"/>
                        <rect x="54" y="78" width="8" height="8" fill="#078930" rx="1"/>
                        <rect x="67" y="75" width="8" height="8" fill="#FCDD09" rx="1"/>
                        <rect x="80" y="78" width="8" height="8" fill="#EF1C24" rx="1"/>
                        <circle cx="15" cy="15" r="2" fill="#fbd38d"/>
                        <circle cx="45" cy="8" r="2.5" fill="#fbd38d"/>
                        <circle cx="65" cy="12" r="2" fill="#fbd38d"/>
                        <rect x="32" y="52" width="36" height="22" fill="#667eea" rx="2"/>
                        <line x1="50" y1="52" x2="50" y2="74" stroke="white" stroke-width="2"/>
                        <rect x="34" y="54" width="14" height="10" fill="white" rx="1"/>
                        <rect x="52" y="54" width="14" height="10" fill="white" rx="1"/>
                        <rect x="25" y="48" width="50" height="4" fill="#2d3748" rx="1"/>
                        <polygon points="50,40 20,48 80,48 50,40" fill="#2d3748"/>
                        <circle cx="50" cy="40" r="3" fill="#FCDD09"/>
                    </svg>
                </div>
                <div class="logo-text">
                    <div class="logo-title" style="color: #ffffff;">Theta <span style="font-weight: 300; opacity: 0.85;">Tutorial</span></div>
                    <div class="logo-subtitle" style="color: rgba(255,255,255,0.8);">Empowering Ethiopian Minds</div>
                    <div class="logo-tagline" style="color: rgba(255,255,255,0.6);">🇪🇹 Excellence in Education</div>
                </div>
            </div>
        </div>
        <div class="nav-links">
            <a href="/quiz-list/"><i class="fas fa-pencil-alt"></i> Quizzes</a>
            <a href="/student-logout/" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="container">
        <!-- PROFILE SECTION -->
        <div class="profile-section fade-in">
            <img class="fasil-image" src="{% static 'images/fasil.jpg' %}" alt="Fasil Castle Gondar">
            <img class="obelisk-image" src="{% static 'images/axum.jpg' %}" alt="Axum Obelisk">

            <div class="profile-picture">
                {% if student.profile_picture %}
                    <img src="{{ student.profile_picture.url }}" alt="{{ student.name }}">
                {% else %}
                    <div class="initial">{{ student.name|first }}</div>
                {% endif %}
            </div>
            <div class="profile-info">
                <h2>Welcome back, <span>{{ student.name }}</span>! 👋</h2>
                <p>
                    <i class="fas fa-graduation-cap" style="color: var(--primary);"></i> 
                    Grade {{ student.grade }} &nbsp;|&nbsp; 
                    <i class="fas fa-id-card" style="color: var(--gray);"></i> 
                    ID: {{ student.id }}
                </p>
                <p style="font-size: 13px; margin-top: 4px;">
                    <i class="fas fa-envelope" style="color: var(--gray);"></i> 
                    {{ student.email|default:"Email not provided" }} &nbsp;|&nbsp;
                    <i class="fas fa-phone" style="color: var(--gray);"></i> 
                    {{ student.phone|default:"Phone not provided" }}
                </p>
                <span class="badge">
                    <i class="fas fa-calendar-alt"></i> Registered: {{ student.registered_date|date:"M d, Y" }}
                </span>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card fade-in">
                <span class="stat-icon">📖</span>
                <div class="value primary">{{ total_lessons }}</div>
                <div class="label">Total Lessons</div>
            </div>
            <div class="stat-card fade-in">
                <span class="stat-icon">✅</span>
                <div class="value success">{{ completed_lessons }}</div>
                <div class="label">Completed</div>
            </div>
            <div class="stat-card fade-in">
                <span class="stat-icon">📊</span>
                <div class="value warning">{{ completion_rate }}%</div>
                <div class="label">Completion Rate</div>
            </div>
            <div class="stat-card fade-in">
                <span class="stat-icon">💳</span>
                <div class="value {% if payment_status == 'Paid' %}success{% else %}danger{% endif %}">{{ payment_status }}</div>
                <div class="label">Payment Status</div>
            </div>
        </div>

        <!-- LESSONS -->
        <div class="section">
            <div class="section-header">
                <h3>
                    <i class="fas fa-book-open" style="color: var(--primary);"></i>
                    My Lessons
                    <span class="count">{{ lessons|length }}</span>
                </h3>
            </div>

            {% if lessons %}
                {% for lesson in lessons %}
                <div class="lesson-item fade-in">
                    <div class="lesson-info">
                        <div class="lesson-title">
                            {{ lesson.title }}
                            {% if lesson.content_type %}
                                <span class="lesson-type {{ lesson.content_type }}">{{ lesson.content_type }}</span>
                            {% endif %}
                        </div>
                        <div class="lesson-topic">
                            <i class="fas fa-tag" style="color: var(--gray);"></i> {{ lesson.topic }}
                        </div>
                        {% if lesson.video_url %}
                            <button class="watch-video-btn" onclick="openVideo('{{ lesson.video_url }}', '{{ lesson.title }}')">
                                <i class="fas fa-play"></i> Watch Video
                            </button>
                        {% else %}
                            <span class="no-video"><i class="fas fa-video-slash"></i> No video available</span>
                        {% endif %}
                    </div>
                    <div class="lesson-progress">
                        <div class="progress-wrapper">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: {{ lesson.progress }}%;"></div>
                            </div>
                            <span class="progress-text">{{ lesson.progress }}%</span>
                        </div>
                        {% if lesson.progress >= 100 %}
                            <span class="status-badge status-completed">
                                <i class="fas fa-check-circle"></i> Completed
                            </span>
                        {% elif lesson.progress > 0 %}
                            <span class="status-badge status-in_progress">
                                <i class="fas fa-spinner fa-pulse"></i> In Progress
                            </span>
                        {% else %}
                            <span class="status-badge status-not_started">
                                <i class="fas fa-hourglass-start"></i> Not Started
                            </span>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <p style="text-align: center; color: var(--gray); padding: 30px 0;">
                    <i class="fas fa-inbox" style="font-size: 40px; display: block; margin-bottom: 10px;"></i>
                    No lessons assigned yet.
                </p>
            {% endif %}
        </div>
    </div>

    <!-- VIDEO MODAL -->
    <div class="video-modal" id="videoModal">
        <div class="video-modal-content">
            <button class="video-modal-close" onclick="closeVideo()">×</button>
            <h2 class="video-modal-title" id="videoTitle">Video Lesson</h2>
            <div class="video-container">
                <iframe id="videoIframe" src="" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
            </div>
            <div class="video-actions">
                <button class="btn-close" onclick="closeVideo()"><i class="fas fa-times"></i> Close</button>
                <button class="btn-complete" onclick="showConfetti()"><i class="fas fa-check"></i> Mark as Completed</button>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="ethiopian-footer">
        <img class="footer-fasil" src="{% static 'images/fasil.jpg' %}" alt="Fasil Castle Gondar">
        <img class="footer-obelisk" src="{% static 'images/axum.jpg' %}" alt="Axum Obelisk">

        <div class="flag-colors">
            <span class="green">■</span>
            <span class="yellow">■</span>
            <span class="red">■</span>
            <span style="color: #4a5568;">|</span>
            <span style="color: #f6ad55;">☀️</span>
            <span style="color: #4a5568;">|</span>
            <span style="color: #4a5568;">🏔️</span>
            <span style="color: #4a5568;">|</span>
            <span style="color: #fbd38d;">⭐</span>
        </div>

        <div class="footer-brand">
            📚 Theta <span>Tutorial Center</span>
        </div>

        <div class="footer-contact">
            <a href="mailto:Yonasmolla3@gmail.com">
                <i class="fas fa-envelope"></i> Yonasmolla3@gmail.com
            </a>
            <a href="tel:+2571713183737">
                <i class="fas fa-phone"></i> +257 17 1318 3737
            </a>
            <a href="#">
                <i class="fas fa-map-marker-alt"></i> Addis Ababa, Ethiopia
            </a>
        </div>

        <hr class="footer-divider">

        <p class="tagline">© 2026 Theta Tutorial Center | Built with ❤️ in Ethiopia</p>
        <p class="tagline" style="margin-top: 4px; font-size: 11px;">
            <i class="fas fa-graduation-cap" style="color: #667eea;"></i> 
            Empowering the next generation of Ethiopian leaders
        </p>
    </footer>

    <script>
        function openVideo(videoUrl, videoTitle) {
            document.getElementById('videoModal').style.display = 'flex';
            document.getElementById('videoTitle').textContent = videoTitle || 'Video Lesson';
            
            let embedUrl = videoUrl;
            
            if (videoUrl.includes('watch?v=')) {
                embedUrl = videoUrl.replace('watch?v=', 'embed/');
            }
            else if (videoUrl.includes('youtu.be/')) {
                embedUrl = videoUrl.replace('youtu.be/', 'www.youtube.com/embed/');
            }
            else if (videoUrl.includes('embed/')) {
                embedUrl = videoUrl;
            }
            else if (videoUrl.includes('vimeo.com/')) {
                embedUrl = videoUrl.replace('vimeo.com/', 'player.vimeo.com/video/');
            }
            else if (videoUrl.length === 11 && !videoUrl.includes('http')) {
                embedUrl = 'https://www.youtube.com/embed/' + videoUrl;
            }
            
            if (embedUrl.includes('?')) {
                embedUrl += '&autoplay=1';
            } else {
                embedUrl += '?autoplay=1';
            }
            
            document.getElementById('videoIframe').src = embedUrl;
            document.body.style.overflow = 'hidden';
        }

        function closeVideo() {
            document.getElementById('videoModal').style.display = 'none';
            document.getElementById('videoIframe').src = '';
            document.body.style.overflow = 'auto';
        }

        function showConfetti() {
            const colors = ['#078930', '#FCDD09', '#EF1C24', '#667eea', '#764ba2', '#48bb78', '#ed8936', '#fc8181'];
            const container = document.createElement('div');
            container.className = 'confetti-container';
            document.body.appendChild(container);
            
            for (let i = 0; i < 100; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'confetti';
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.width = (Math.random() * 8 + 4) + 'px';
                confetti.style.height = (Math.random() * 8 + 4) + 'px';
                confetti.style.animationDuration = (Math.random() * 2 + 2) + 's';
                confetti.style.animationDelay = Math.random() * 2 + 's';
                confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
                container.appendChild(confetti);
            }
            
            alert('🎉 Congratulations! Lesson marked as complete! 🎉');
            closeVideo();
            
            setTimeout(() => {
                container.remove();
            }, 5000);
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeVideo();
            }
        });

        document.getElementById('videoModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeVideo();
            }
        });
    </script>
</body>
</html>